</div>

<!-- ABOUT PAGE -->
<div id="page-about" class="page">
  <div class="page-header">
    <h2>About <span>HackArena</span></h2>
    <p>Built by students, informed by research — designed to fix what the others got wrong.</p>
  </div>
  <div class="about-grid">
