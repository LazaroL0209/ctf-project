<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HackArena CTF</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600;700&family=Exo+2:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:#0a0e1a;--bg2:#0f1524;--bg3:#141929;
    --accent:#00f5c4;--accent2:#7c3aed;--accent3:#f59e0b;
    --text:#e2e8f0;--text2:#94a3b8;--card:#111827;
    --border:rgba(0,245,196,0.15);--red:#ef4444;--green:#10b981;--blue:#3b82f6;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:var(--bg);color:var(--text);font-family:'Exo 2',sans-serif;min-height:100vh;overflow-x:hidden;}
  body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,245,196,0.03) 1px,transparent 1px),linear-gradient(90deg,rgba(0,245,196,0.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;}

  /* AUTH SCREEN */
  #auth-screen{position:fixed;inset:0;z-index:999;background:var(--bg);display:flex;align-items:center;justify-content:center;padding:1rem;}
  #auth-screen.hidden{display:none;}
  .auth-box{background:var(--bg2);border:1px solid var(--border);width:100%;max-width:420px;padding:2.5rem;position:relative;z-index:1;}
  .auth-logo{font-family:'Share Tech Mono',monospace;font-size:1.6rem;color:var(--accent);letter-spacing:3px;text-align:center;margin-bottom:0.5rem;}
  .auth-logo span{color:var(--accent2);}
  .auth-tagline{font-size:0.78rem;color:var(--text2);text-align:center;letter-spacing:2px;font-family:'Share Tech Mono',monospace;margin-bottom:2rem;}
  .auth-tabs{display:flex;border-bottom:1px solid var(--border);margin-bottom:2rem;}
  .auth-tab{flex:1;padding:10px;text-align:center;font-size:0.8rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;cursor:pointer;color:var(--text2);border:none;background:none;font-family:'Exo 2',sans-serif;transition:all 0.2s;border-bottom:2px solid transparent;margin-bottom:-1px;}
  .auth-tab.active{color:var(--accent);border-bottom-color:var(--accent);}
  .auth-form{display:none;flex-direction:column;gap:1rem;}
  .auth-form.active{display:flex;}
  .auth-label{font-size:0.72rem;font-family:'Share Tech Mono',monospace;letter-spacing:2px;color:var(--text2);display:block;margin-bottom:4px;}
  .auth-input{width:100%;background:var(--bg3);border:1px solid rgba(255,255,255,0.1);color:var(--text);padding:11px 14px;font-family:'Share Tech Mono',monospace;font-size:0.9rem;outline:none;transition:border 0.2s;}
  .auth-input:focus{border-color:var(--accent);}
  .auth-input::placeholder{color:var(--text2);opacity:0.4;}
  .auth-btn{width:100%;background:var(--accent);color:var(--bg);border:none;padding:13px;font-family:'Exo 2',sans-serif;font-size:0.95rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all 0.2s;margin-top:0.5rem;clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%);}
  .auth-btn:hover{background:#00d4a8;}
  .auth-err{font-family:'Share Tech Mono',monospace;font-size:0.75rem;color:var(--red);display:none;padding:8px 12px;border:1px solid rgba(239,68,68,0.2);background:rgba(239,68,68,0.05);}
  .auth-err.show{display:block;}
  .auth-ok{font-family:'Share Tech Mono',monospace;font-size:0.75rem;color:var(--green);display:none;padding:8px 12px;border:1px solid rgba(16,185,129,0.2);background:rgba(16,185,129,0.05);}
  .auth-ok.show{display:block;}
  .auth-divider{display:flex;align-items:center;gap:1rem;margin:0.25rem 0;}
  .auth-divider span{font-size:0.7rem;color:var(--text2);font-family:'Share Tech Mono',monospace;white-space:nowrap;}
  .auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:rgba(255,255,255,0.08);}
  .guest-btn{width:100%;background:transparent;color:var(--text2);border:1px solid rgba(255,255,255,0.1);padding:11px;font-family:'Exo 2',sans-serif;font-size:0.85rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all 0.2s;}
  .guest-btn:hover{border-color:var(--accent2);color:var(--accent2);}

  /* NAV */
  nav{position:sticky;top:0;z-index:100;background:rgba(10,14,26,0.97);border-bottom:1px solid var(--border);padding:0 2rem;display:flex;align-items:center;justify-content:space-between;height:64px;}
  .logo{font-family:'Share Tech Mono',monospace;font-size:1.4rem;color:var(--accent);letter-spacing:2px;display:flex;align-items:center;gap:8px;cursor:pointer;}
  .logo-bracket{color:var(--accent2);}
  .nav-links{list-style:none;display:flex;gap:2rem;}
  .nav-links li a{color:var(--text2);text-decoration:none;font-size:0.875rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;transition:color 0.2s;cursor:pointer;border:none;background:none;font-family:'Exo 2',sans-serif;padding:0;}
  .nav-links li a:hover,.nav-links li a.active{color:var(--accent);}
  .nav-right{display:flex;align-items:center;gap:1rem;}
  .nav-user{font-family:'Share Tech Mono',monospace;font-size:0.8rem;color:var(--accent);display:flex;align-items:center;gap:8px;}
  .nav-user-dot{width:8px;height:8px;border-radius:50%;background:var(--green);}
  .nav-score-pill{background:rgba(0,245,196,0.08);border:1px solid var(--border);padding:4px 12px;font-family:'Share Tech Mono',monospace;font-size:0.78rem;color:var(--accent);}
  .nav-btn{background:transparent;border:1px solid rgba(255,255,255,0.15);color:var(--text2);padding:7px 16px;font-family:'Exo 2',sans-serif;font-size:0.8rem;font-weight:600;letter-spacing:1px;cursor:pointer;transition:all 0.2s;text-transform:uppercase;}
  .nav-btn:hover{border-color:var(--red);color:var(--red);}

  /* PAGES */
  .page{display:none;position:relative;z-index:1;}
  .page.active{display:block;}

  /* HOME */
  .hero{min-height:calc(100vh - 64px);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:4rem 2rem;position:relative;}
  .hero-badge{font-family:'Share Tech Mono',monospace;font-size:0.75rem;color:var(--accent);border:1px solid var(--border);padding:6px 16px;letter-spacing:3px;margin-bottom:2rem;animation:fadeInDown 0.6s ease;}
  .hero h1{font-family:'Rajdhani',sans-serif;font-size:clamp(3rem,8vw,7rem);font-weight:700;line-height:1;margin-bottom:1rem;animation:fadeInUp 0.7s ease 0.1s both;}
  .hero h1 span{color:var(--accent);}
  .hero h1 em{color:var(--accent2);font-style:normal;}
  .hero-sub{font-size:1.1rem;color:var(--text2);max-width:600px;line-height:1.7;margin-bottom:3rem;animation:fadeInUp 0.7s ease 0.2s both;}
  .hero-actions{display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;animation:fadeInUp 0.7s ease 0.3s both;}
  .btn-primary{background:var(--accent);color:var(--bg);border:none;padding:14px 36px;font-family:'Exo 2',sans-serif;font-size:1rem;font-weight:700;letter-spacing:1px;cursor:pointer;text-transform:uppercase;transition:all 0.2s;clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);}
  .btn-primary:hover{background:#00d4a8;transform:translateY(-2px);}
  .btn-secondary{background:transparent;color:var(--text);border:1px solid rgba(255,255,255,0.2);padding:14px 36px;font-family:'Exo 2',sans-serif;font-size:1rem;font-weight:600;letter-spacing:1px;cursor:pointer;text-transform:uppercase;transition:all 0.2s;}
  .btn-secondary:hover{border-color:var(--accent2);color:var(--accent2);}
  .stats-bar{display:flex;justify-content:center;gap:4rem;flex-wrap:wrap;padding:3rem 2rem;border-top:1px solid var(--border);border-bottom:1px solid var(--border);margin:4rem 2rem 0;}
  .stat{text-align:center;}
  .stat-num{font-family:'Rajdhani',sans-serif;font-size:2.5rem;font-weight:700;color:var(--accent);display:block;line-height:1;}
  .stat-label{font-size:0.75rem;color:var(--text2);letter-spacing:2px;text-transform:uppercase;margin-top:4px;display:block;}

  /* CHALLENGES */
  .page-header{padding:3rem 2rem 1rem;border-bottom:1px solid var(--border);}
  .page-header h2{font-family:'Rajdhani',sans-serif;font-size:2.5rem;font-weight:700;}
  .page-header h2 span{color:var(--accent);}
  .page-header p{color:var(--text2);margin-top:0.5rem;}
  .filter-bar{display:flex;gap:0.75rem;flex-wrap:wrap;padding:1.5rem 2rem;border-bottom:1px solid var(--border);}
  .filter-btn{padding:6px 18px;border:1px solid rgba(255,255,255,0.1);background:transparent;color:var(--text2);font-family:'Exo 2',sans-serif;font-size:0.8rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all 0.2s;border-radius:2px;}
  .filter-btn:hover,.filter-btn.active{border-color:var(--accent);color:var(--accent);background:rgba(0,245,196,0.05);}
  .challenges-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem;padding:2rem;}
  .challenge-card{background:var(--card);border:1px solid rgba(255,255,255,0.06);padding:1.5rem;cursor:pointer;transition:all 0.25s;position:relative;overflow:hidden;}
  .challenge-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
  .challenge-card.web::before{background:var(--blue);}
  .challenge-card.crypto::before{background:var(--accent2);}
  .challenge-card.forensics::before{background:var(--accent3);}
  .challenge-card.pwn::before{background:var(--red);}
  .challenge-card.misc::before{background:var(--green);}
  .challenge-card.rev::before{background:var(--accent);}
  .challenge-card:hover{border-color:rgba(0,245,196,0.3);transform:translateY(-3px);background:#161e30;}
  .challenge-card.solved{opacity:0.6;}
  .challenge-card.solved::after{content:'SOLVED';position:absolute;top:12px;right:12px;font-family:'Share Tech Mono',monospace;font-size:0.65rem;color:var(--green);border:1px solid var(--green);padding:2px 8px;letter-spacing:2px;}
  .card-cat{font-family:'Share Tech Mono',monospace;font-size:0.7rem;letter-spacing:2px;text-transform:uppercase;margin-bottom:0.75rem;}
  .card-cat.web{color:var(--blue);}.card-cat.crypto{color:var(--accent2);}.card-cat.forensics{color:var(--accent3);}.card-cat.pwn{color:var(--red);}.card-cat.misc{color:var(--green);}.card-cat.rev{color:var(--accent);}
  .card-title{font-family:'Rajdhani',sans-serif;font-size:1.2rem;font-weight:600;margin-bottom:0.5rem;}
  .card-desc{font-size:0.82rem;color:var(--text2);line-height:1.6;margin-bottom:1rem;}
  .card-footer{display:flex;align-items:center;justify-content:space-between;}
  .card-points{font-family:'Share Tech Mono',monospace;font-size:1.1rem;color:var(--accent);font-weight:700;}
  .card-diff{display:flex;gap:3px;}
  .diff-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.15);}
  .diff-dot.filled{background:var(--accent3);}
  .card-solves{font-size:0.75rem;color:var(--text2);margin-top:0.5rem;}

  /* LEADERBOARD */
  .leaderboard-container{padding:2rem;}
  .lb-table{width:100%;border-collapse:collapse;}
  .lb-table thead tr{border-bottom:1px solid var(--border);}
  .lb-table th{font-family:'Share Tech Mono',monospace;font-size:0.7rem;letter-spacing:2px;text-transform:uppercase;color:var(--text2);padding:0 1rem 1rem 0;text-align:left;font-weight:400;}
  .lb-table tbody tr{border-bottom:1px solid rgba(255,255,255,0.04);transition:background 0.15s;}
  .lb-table tbody tr:hover{background:rgba(0,245,196,0.03);}
  .lb-table td{padding:1rem 1rem 1rem 0;font-size:0.9rem;}
  .lb-table tr.you-row td{background:rgba(0,245,196,0.04);}
  .you-tag{font-family:'Share Tech Mono',monospace;font-size:0.6rem;color:var(--accent);border:1px solid var(--accent);padding:1px 6px;letter-spacing:1px;margin-left:8px;vertical-align:middle;}
  .rank{font-family:'Rajdhani',sans-serif;font-size:1.4rem;font-weight:700;width:60px;}
  .rank-1{color:var(--accent3);}.rank-2{color:#94a3b8;}.rank-3{color:#b45309;}.rank-other{color:var(--text2);}
  .lb-name{font-weight:600;font-size:1rem;display:flex;align-items:center;gap:10px;}
  .lb-avatar{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;font-family:'Rajdhani',sans-serif;flex-shrink:0;}
  .lb-score{font-family:'Share Tech Mono',monospace;color:var(--accent);font-size:1rem;}
  .progress-bar-wrap{background:rgba(255,255,255,0.06);height:4px;border-radius:2px;width:120px;overflow:hidden;}
  .progress-bar-fill{height:100%;background:var(--accent);border-radius:2px;transition:width 0.5s ease;}

  /* ABOUT */
  .about-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.5rem;padding:2rem;}
  .about-card{background:var(--card);border:1px solid rgba(255,255,255,0.06);padding:2rem;position:relative;overflow:hidden;}
  .about-card::before{content:'';position:absolute;top:0;left:0;bottom:0;width:3px;}
  .about-card.green::before{background:var(--green);}.about-card.purple::before{background:var(--accent2);}.about-card.amber::before{background:var(--accent3);}.about-card.teal::before{background:var(--accent);}
  .about-icon{font-size:2rem;margin-bottom:1rem;display:block;}
  .about-card h3{font-family:'Rajdhani',sans-serif;font-size:1.3rem;font-weight:700;margin-bottom:0.75rem;}
  .about-card p{font-size:0.875rem;color:var(--text2);line-height:1.7;}
  .team-section{padding:2rem;border-top:1px solid var(--border);}
  .team-section h3{font-family:'Rajdhani',sans-serif;font-size:1.8rem;font-weight:700;margin-bottom:1.5rem;}
  .team-section h3 span{color:var(--accent);}
  .team-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:1rem;}
  .team-card{background:var(--card);border:1px solid rgba(255,255,255,0.06);padding:1.25rem;text-align:center;transition:all 0.2s;}
  .team-card:hover{border-color:var(--border);transform:translateY(-2px);}
  .team-avatar{width:52px;height:52px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Rajdhani',sans-serif;font-size:1rem;font-weight:700;margin:0 auto 0.75rem;}
  .team-name{font-size:0.875rem;font-weight:600;color:var(--text);margin-bottom:0.25rem;}
  .team-role{font-family:'Share Tech Mono',monospace;font-size:0.65rem;color:var(--text2);letter-spacing:1px;}

  /* MODAL */
  .modal-overlay{display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,0.85);align-items:center;justify-content:center;padding:1rem;}
  .modal-overlay.open{display:flex;}
  .modal{background:var(--bg2);border:1px solid var(--border);max-width:560px;width:100%;padding:2rem;position:relative;animation:fadeInUp 0.25s ease;max-height:90vh;overflow-y:auto;}
  .modal-close{position:absolute;top:1rem;right:1rem;background:none;border:none;color:var(--text2);font-size:1.25rem;cursor:pointer;}
  .modal-close:hover{color:var(--text);}
  .modal-cat{font-family:'Share Tech Mono',monospace;font-size:0.7rem;letter-spacing:2px;margin-bottom:0.75rem;}
  .modal-title{font-family:'Rajdhani',sans-serif;font-size:1.8rem;font-weight:700;margin-bottom:0.5rem;}
  .modal-points{font-family:'Share Tech Mono',monospace;color:var(--accent);font-size:1rem;margin-bottom:1.25rem;}
  .modal-desc{font-size:0.9rem;color:var(--text2);line-height:1.7;margin-bottom:1.5rem;}
  .hint-box{background:rgba(0,245,196,0.05);border:1px solid rgba(0,245,196,0.15);padding:1rem;margin-bottom:1.5rem;font-size:0.85rem;color:var(--text2);display:none;}
  .hint-box.open{display:block;}
  .hint-label{font-family:'Share Tech Mono',monospace;font-size:0.65rem;letter-spacing:2px;color:var(--accent);margin-bottom:0.5rem;display:block;}
  .flag-input-wrap{display:flex;gap:0.75rem;}
  .flag-input{flex:1;background:var(--bg3);border:1px solid rgba(255,255,255,0.1);color:var(--text);padding:10px 14px;font-family:'Share Tech Mono',monospace;font-size:0.9rem;outline:none;transition:border 0.2s;}
  .flag-input:focus{border-color:var(--accent);}
  .flag-input::placeholder{color:var(--text2);opacity:0.5;}
  .submit-btn{background:var(--accent);color:var(--bg);border:none;padding:10px 20px;font-family:'Exo 2',sans-serif;font-size:0.875rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;cursor:pointer;transition:all 0.2s;}
  .submit-btn:hover{background:#00d4a8;}
  .flag-msg{margin-top:0.75rem;font-family:'Share Tech Mono',monospace;font-size:0.8rem;display:none;}
  .flag-msg.correct{color:var(--green);display:block;}
  .flag-msg.wrong{color:var(--red);display:block;}
  .hint-toggle{background:none;border:1px solid rgba(255,255,255,0.1);color:var(--text2);padding:6px 14px;font-family:'Exo 2',sans-serif;font-size:0.8rem;cursor:pointer;transition:all 0.2s;margin-bottom:1rem;display:block;}
  .hint-toggle:hover{border-color:var(--accent3);color:var(--accent3);}

  /* TOAST */
  .toast{position:fixed;bottom:2rem;right:2rem;z-index:500;background:var(--bg2);border:1px solid var(--green);padding:1rem 1.5rem;font-family:'Share Tech Mono',monospace;font-size:0.85rem;color:var(--green);transform:translateY(100px);opacity:0;transition:all 0.35s ease;max-width:320px;}
  .toast.show{transform:translateY(0);opacity:1;}

  @keyframes fadeInUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
  @keyframes fadeInDown{from{opacity:0;transform:translateY(-10px)}to{opacity:1;transform:translateY(0)}}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}
  .blink{animation:pulse 1.5s ease infinite;}
  ::-webkit-scrollbar{width:6px}
  ::-webkit-scrollbar-track{background:var(--bg)}
  ::-webkit-scrollbar-thumb{background:rgba(0,245,196,0.2);border-radius:3px}
</style>
</head>
<body>

<!-- AUTH SCREEN -->
<div id="auth-screen">
  <div class="auth-box">
    <div class="auth-logo"><span>[</span>HACK<span style="color:var(--text)">ARENA</span><span>]</span></div>
    <div class="auth-tagline">&#9632; CAPTURE THE FLAG PLATFORM</div>
    <div class="auth-tabs">
      <button class="auth-tab active" onclick="switchTab('login')">Login</button>
      <button class="auth-tab" onclick="switchTab('register')">Register</button>
    </div>
    <!-- LOGIN -->
    <form class="auth-form active" id="form-login" onsubmit="handleLogin(event)">
      <div>
        <label class="auth-label">Username</label>
        <input class="auth-input" id="login-user" type="text" placeholder="your_handle" autocomplete="off" />
      </div>
      <div>
        <label class="auth-label">Password</label>
        <input class="auth-input" id="login-pass" type="password" placeholder="••••••••" />
      </div>
      <div class="auth-err" id="login-err"></div>
      <button class="auth-btn" type="submit">Login</button>
      <div class="auth-divider"><span>or</span></div>
      <button class="guest-btn" type="button" onclick="enterAsGuest()">Continue as Guest</button>
    </form>
    <!-- REGISTER -->
    <form class="auth-form" id="form-register" onsubmit="handleRegister(event)">
      <div>
        <label class="auth-label">Username</label>
        <input class="auth-input" id="reg-user" type="text" placeholder="choose_a_handle" autocomplete="off" />
      </div>
      <div>
        <label class="auth-label">Email</label>
        <input class="auth-input" id="reg-email" type="email" placeholder="you@example.com" />
      </div>
      <div>
        <label class="auth-label">Password</label>
        <input class="auth-input" id="reg-pass" type="password" placeholder="min. 6 characters" />
      </div>
      <div class="auth-err" id="reg-err"></div>
      <div class="auth-ok" id="reg-ok"></div>
      <button class="auth-btn" type="submit">Create Account</button>
      <div class="auth-divider"><span>or</span></div>
      <button class="guest-btn" type="button" onclick="enterAsGuest()">Continue as Guest</button>
    </form>
  </div>
</div>

<!-- MAIN APP -->
<div id="app" style="display:none">
<nav>
  <div class="logo" onclick="goTo('home')">
    <span class="logo-bracket">[</span>HACK<span style="color:var(--text)">ARENA</span><span class="logo-bracket">]</span>
  </div>
  <ul class="nav-links">
    <li><a id="nav-home" onclick="goTo('home')">Home</a></li>
    <li><a id="nav-challenges" onclick="goTo('challenges')">Challenges</a></li>
    <li><a id="nav-leaderboard" onclick="goTo('leaderboard')">Leaderboard</a></li>
    <li><a id="nav-about" onclick="goTo('about')">About</a></li>
  </ul>
  <div class="nav-right">
    <span class="nav-user"><span class="nav-user-dot"></span><span id="nav-username"></span></span>
    <span class="nav-score-pill" id="nav-score">0 pts</span>
    <button class="nav-btn" onclick="logout()">Logout</button>
  </div>
</nav>

<!-- HOME PAGE -->
<div id="page-home" class="page active">
  <div class="hero">
    <div class="hero-badge blink">&#9632; COMPETITION ACTIVE — 14D 06H 22M REMAINING</div>
    <h1>HACK THE <span>FLAG.</span><br><em>PROVE</em> YOUR SKILLS.</h1>
    <p class="hero-sub">A CTF platform built on what picoCTF and TryHackMe got right — clean navigation, real depth, meaningful hints, and challenges that actually make you think.</p>
    <div class="hero-actions">
      <button class="btn-primary" onclick="goTo('challenges')">Start Hacking</button>
      <button class="btn-secondary" onclick="goTo('about')">Learn More</button>
    </div>
  </div>
  <div class="stats-bar">
    <div class="stat"><span class="stat-num">16</span><span class="stat-label">Challenges</span></div>
    <div class="stat"><span class="stat-num">6</span><span class="stat-label">Categories</span></div>
    <div class="stat"><span class="stat-num">312</span><span class="stat-label">Players</span></div>
    <div class="stat"><span class="stat-num">9,400</span><span class="stat-label">Flags Captured</span></div>
    <div class="stat"><span class="stat-num">14</span><span class="stat-label">Days Left</span></div>
  </div>
</div>

<!-- CHALLENGES PAGE -->
<div id="page-challenges" class="page">
  <div class="page-header">
    <h2>Challenge <span>Arena</span></h2>
    <p>Select a category or browse all. Each flag earned adds to your score and the leaderboard.</p>
  </div>
  <div class="filter-bar">
    <button class="filter-btn active" onclick="filterCards('all',this)">All</button>
    <button class="filter-btn" onclick="filterCards('web',this)">Web Exploit</button>
    <button class="filter-btn" onclick="filterCards('crypto',this)">Cryptography</button>
