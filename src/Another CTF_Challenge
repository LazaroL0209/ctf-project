    <div class="about-card purple"><span class="about-icon">&#127981;</span><h3>Structured Learning Paths</h3><p>We took TryHackMe's idea of guided paths and made them clearer. Each category has a recommended order and every challenge explains what skill you're building.</p></div>
    <div class="about-card amber"><span class="about-icon">&#129351;</span><h3>Real Gamification</h3><p>Points, streaks, and leaderboards that actually mean something. Earned badges reflect real milestones — not just clicking "next."</p></div>
    <div class="about-card green"><span class="about-icon">&#128161;</span><h3>Hints Without Handholding</h3><p>Hints guide — they never solve. Our hints nudge you toward independent problem-solving, preserving the challenge and the learning.</p></div>
    <div class="about-card teal"><span class="about-icon">&#127758;</span><h3>Real-World Context</h3><p>Every challenge explains why the skill matters. Not just "find the flag" — but here's where this vulnerability exists and why it's critical.</p></div>
    <div class="about-card purple"><span class="about-icon">&#128640;</span><h3>Beginner to Advanced</h3><p>Difficulty scales naturally. Beginners start with clearly labeled entry-level challenges. No experience needed to get started.</p></div>
  </div>
  <div class="team-section">
    <h3>The <span>Team</span></h3>
    <div class="team-grid" id="team-grid"></div>
  </div>
</div>
</div><!-- end #app -->

<!-- CHALLENGE MODAL -->
<div class="modal-overlay" id="modal" onclick="closeModalOnBg(event)">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">&#10005;</button>
    <div class="modal-cat" id="m-cat"></div>
    <div class="modal-title" id="m-title"></div>
    <div class="modal-points" id="m-pts"></div>
    <div class="modal-desc" id="m-desc"></div>
    <button class="hint-toggle" id="hint-toggle-btn" onclick="toggleHint()">&#128161; Show Hint</button>
    <div class="hint-box" id="hint-box"><span class="hint-label">HINT</span><span id="hint-text"></span></div>
    <div class="flag-input-wrap">
      <input class="flag-input" id="flag-input" type="text" placeholder="flag{your_answer_here}" />
      <button class="submit-btn" onclick="submitFlag()">Submit</button>
    </div>
    <div class="flag-msg" id="flag-msg"></div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const challenges = [
  {id:1,cat:'web',title:'Cookie Monster',desc:'A login form is hiding something sweet. Inspect what your browser stores after authenticating.',pts:100,diff:1,solves:287,hint:'Developer tools → Application tab → Cookies',flag:'flag{c00k13_auth_bypass}',solved:false},
  {id:2,cat:'web',title:'SQL Injection 101',desc:'The search bar on this page takes your input literally. Can you make it return what it was never meant to?',pts:150,diff:2,solves:214,hint:'Try a single quote and watch what breaks.',flag:'flag{sqli_union_select}',solved:false},
  {id:3,cat:'web',title:'XSS Playground',desc:'The comment section reflects your input back. What happens if your input is more than just text?',pts:200,diff:2,solves:178,hint:'Script tags are your friend... or enemy.',flag:'flag{xss_reflected_win}',solved:false},
  {id:4,cat:'crypto',title:'Caesar Salad',desc:'A classic shift cipher scrambled this message. The key is somewhere between 1 and 25.',pts:75,diff:1,solves:312,hint:'ROT13 is just a special case of Caesar.',flag:'flag{julius_would_be_proud}',solved:false},
  {id:5,cat:'crypto',title:'Base Jumping',desc:"This encoded string looks suspicious. It ends in == and that's a clue.",pts:75,diff:1,solves:298,hint:'Base64 encoding always pads with = signs.',flag:'flag{base64_decoded}',solved:false},
  {id:6,cat:'crypto',title:'RSA Warm-Up',desc:'Two small primes were used to generate this RSA key pair. Factor them and recover the private key.',pts:300,diff:3,solves:89,hint:'p and q are suspiciously close — try Fermat factorization.',flag:'flag{rsa_small_primes_bad}',solved:false},
  {id:7,cat:'forensics',title:'Hidden in Plain Sight',desc:'This image file is more than it appears. Something was embedded inside before it was uploaded.',pts:150,diff:2,solves:167,hint:'Try running strings or binwalk on the file.',flag:'flag{steganography_rocks}',solved:false},
  {id:8,cat:'forensics',title:'Packet Detective',desc:'A PCAP file captured some suspicious traffic. Find the credentials passed in plaintext.',pts:200,diff:2,solves:143,hint:'Filter for HTTP POST requests in Wireshark.',flag:'flag{wireshark_is_powerful}',solved:false},
  {id:9,cat:'forensics',title:'Deleted Files',desc:'Someone tried to delete the evidence. Recover what was removed from this disk image.',pts:250,diff:3,solves:76,hint:'Autopsy or Foremost can recover deleted file signatures.',flag:'flag{data_never_truly_dies}',solved:false},
  {id:10,cat:'pwn',title:'Buffer Overflow Basics',desc:'This C program reads input without bounds checking. Overwrite the return address and redirect execution.',pts:300,diff:3,solves:62,hint:'Find the exact offset where EIP/RIP gets overwritten using a cyclic pattern.',flag:'flag{stack_smashed_it}',solved:false},
  {id:11,cat:'pwn',title:'Format String',desc:'printf is being called with user input as the format string. Exploit it.',pts:350,diff:4,solves:41,hint:'%x%x%x%x will leak stack values.',flag:'flag{format_string_leaker}',solved:false},
  {id:12,cat:'rev',title:'License Key',desc:'A program checks for a valid license key. Reverse engineer the validation logic.',pts:200,diff:2,solves:119,hint:'Open the binary in Ghidra and look at the comparison function.',flag:'flag{r3vers3d_the_check}',solved:false},
  {id:13,cat:'rev',title:'Obfuscated Script',desc:'This Python script has been deliberately obfuscated. Deobfuscate it and find what it does.',pts:250,diff:3,solves:94,hint:'Replace exec() with print() to see what gets executed.',flag:'flag{python_deobfuscated}',solved:false},
  {id:14,cat:'misc',title:'OSINT Challenge',desc:'Find everything about fictional company "Nexovara Inc." using only public information.',pts:150,diff:2,solves:201,hint:'WHOIS records and archived pages are your starting point.',flag:'flag{osint_is_a_superpower}',solved:false},
  {id:15,cat:'misc',title:'QR Maze',desc:'This QR code was split into 4 fragments and scrambled. Reassemble them correctly.',pts:100,diff:1,solves:256,hint:'QR codes have finder patterns in three corners — use them to orient each fragment.',flag:'flag{qr_code_reassembled}',solved:false},
  {id:16,cat:'web',title:'JWT Forgery',desc:'The API uses JWT tokens but validates them poorly. Forge a token with admin privileges.',pts:350,diff:4,solves:37,hint:'Check the algorithm field. What happens if you set it to "none"?',flag:'flag{jwt_alg_none_bypass}',solved:false},
];

const seedPlayers = [
  {name:'0xGh0st',score:2850,solved:14,last:'2m ago'},
  {name:'n0va_sec',score:2600,solved:13,last:'18m ago'},
  {name:'bitflip',score:2350,solved:11,last:'1h ago'},
  {name:'pwnmaster',score:2100,solved:10,last:'2h ago'},
  {name:'krypt0girl',score:1950,solved:9,last:'3h ago'},
  {name:'shellcode',score:1700,solved:8,last:'5h ago'},
  {name:'l33thax0r',score:1450,solved:7,last:'8h ago'},
  {name:'reverser99',score:1200,solved:6,last:'12h ago'},
  {name:'flaghunter',score:950,solved:5,last:'1d ago'},
  {name:'newb1337',score:600,solved:3,last:'2d ago'},
];

const catColors = {web:'var(--blue)',crypto:'var(--accent2)',forensics:'var(--accent3)',pwn:'var(--red)',rev:'var(--accent)',misc:'var(--green)'};
const catLabels = {web:'Web Exploit',crypto:'Cryptography',forensics:'Forensics',pwn:'Binary / Pwn',rev:'Reverse Eng.',misc:'Miscellaneous'};
const avatarColors = ['#1d9e75','#7c3aed','#f59e0b','#3b82f6','#ef4444','#00f5c4'];
const team = [
  {name:'Lazaro L.',role:'Lead / PM',color:'#1d9e75'},
  {name:'Richard O.',role:'UI / HTML & File Owner',color:'#7c3aed'},
  {name:'Damian M.',role:'Accessibility',color:'#f59e0b'},
  {name:'Kayla K.',role:'Learning UX',color:'#3b82f6'},
  {name:'Luke B.',role:'Gamification',color:'#ef4444'},
  {name:'Miles B.',role:'Edu. Value',color:'#00f5c4'},
];

const users = {};
let currentUser = null;
let currentChallenge = null;
let currentFilter = 'all';
let leaderboardData = [];

// AUTH
function switchTab(tab) {
  document.querySelectorAll('.auth-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.auth-form').forEach(f => f.classList.remove('active'));
  document.querySelector(`.auth-tab:${tab==='login'?'first-child':'last-child'}`).classList.add('active');
  document.getElementById('form-' + tab).classList.add('active');
}

function handleLogin(e) {
  e.preventDefault();
  const u = document.getElementById('login-user').value.trim();
  const p = document.getElementById('login-pass').value;
  const err = document.getElementById('login-err');
  if (!u || !p) { err.textContent = 'Please fill in all fields.'; err.classList.add('show'); return; }
  if (!users[u]) { err.textContent = 'Account not found. Please register first.'; err.classList.add('show'); return; }
  if (users[u].password !== p) { err.textContent = 'Incorrect password.'; err.classList.add('show'); return; }
  err.classList.remove('show');
  enterApp(u, false);
}

function handleRegister(e) {
  e.preventDefault();
  const u = document.getElementById('reg-user').value.trim();
  const em = document.getElementById('reg-email').value.trim();
  const p = document.getElementById('reg-pass').value;
  const err = document.getElementById('reg-err');
  const ok = document.getElementById('reg-ok');
  if (!u || !em || !p) { err.textContent = 'Please fill in all fields.'; err.classList.add('show'); return; }
  if (p.length < 6) { err.textContent = 'Password must be at least 6 characters.'; err.classList.add('show'); return; }
  if (users[u]) { err.textContent = 'Username already taken.'; err.classList.add('show'); return; }
  err.classList.remove('show');
  users[u] = { password: p, email: em, score: 0, solved: 0, lastSolve: '—' };
  ok.textContent = 'Account created! Logging you in...';
  ok.classList.add('show');
  setTimeout(() => enterApp(u, false), 1000);
}

function enterAsGuest() {
  const guestName = 'guest_' + Math.floor(Math.random() * 9000 + 1000);
  users[guestName] = { password: '', email: '', score: 0, solved: 0, lastSolve: '—' };
  enterApp(guestName, true);
}

function enterApp(username, isGuest) {
  currentUser = username;
  document.getElementById('auth-screen').classList.add('hidden');
  document.getElementById('app').style.display = 'block';
  document.getElementById('nav-username').textContent = username + (isGuest ? ' (guest)' : '');
  document.getElementById('nav-score').textContent = '0 pts';
  buildLeaderboard();
  renderChallenges('all');
  renderLeaderboard();
  renderTeam();
  goTo('home');
}

function logout() {
  currentUser = null;
  challenges.forEach(c => c.solved = false);
  document.getElementById('app').style.display = 'none';
  document.getElementById('auth-screen').classList.remove('hidden');
  document.getElementById('login-user').value = '';
  document.getElementById('login-pass').value = '';
  document.getElementById('login-err').classList.remove('show');
}

// LEADERBOARD
function buildLeaderboard() {
  leaderboardData = [...seedPlayers];
  leaderboardData.push({ name: currentUser, score: users[currentUser].score, solved: users[currentUser].solved, last: users[currentUser].lastSolve, isYou: true });
  leaderboardData.sort((a, b) => b.score - a.score);
}

function renderLeaderboard() {
  const max = Math.max(...leaderboardData.map(p => p.score), 1);
  document.getElementById('lb-body').innerHTML = leaderboardData.map((p, i) => {
    const initials = p.name.substring(0, 2).toUpperCase();
    const rankClass = i===0?'rank-1':i===1?'rank-2':i===2?'rank-3':'rank-other';
    const pct = Math.round((p.score / max) * 100);
    const youTag = p.isYou ? '<span class="you-tag">YOU</span>' : '';
    return `<tr class="${p.isYou ? 'you-row' : ''}">
      <td><span class="rank ${rankClass}">#${i+1}</span></td>
      <td><div class="lb-name"><div class="lb-avatar" style="background:${avatarColors[i%6]}22;color:${avatarColors[i%6]}">${initials}</div>${p.name}${youTag}</div></td>
      <td><span class="lb-score">${p.score.toLocaleString()}</span></td>
      <td style="color:var(--text2)">${p.solved} / ${challenges.length}</td>
      <td><div class="progress-bar-wrap"><div class="progress-bar-fill" style="width:${pct}%"></div></div></td>
      <td style="color:var(--text2);font-size:0.8rem;font-family:'Share Tech Mono',monospace">${p.last}</td>
    </tr>`;
  }).join('');
}

function updateUserScore(pts, challengeTitle) {
  users[currentUser].score += pts;
  users[currentUser].solved += 1;
  users[currentUser].lastSolve = 'just now';
  document.getElementById('nav-score').textContent = users[currentUser].score.toLocaleString() + ' pts';
  buildLeaderboard();
  renderLeaderboard();
  showToast('+ ' + pts + ' pts — ' + challengeTitle + ' captured!');
}

// CHALLENGES
function renderChallenges(filter) {
  currentFilter = filter || currentFilter;
  const grid = document.getElementById('challenges-grid');
  const filtered = currentFilter === 'all' ? challenges : challenges.filter(c => c.cat === currentFilter);
  grid.innerHTML = filtered.map(c => {
    const dots = Array(5).fill(0).map((_, i) => `<div class="diff-dot${i < c.diff ? ' filled' : ''}"></div>`).join('');
    return `<div class="challenge-card ${c.cat}${c.solved ? ' solved' : ''}" onclick="openModal(${c.id})">
      <div class="card-cat ${c.cat}">${catLabels[c.cat]}</div>
      <div class="card-title">${c.title}</div>
      <div class="card-desc">${c.desc}</div>
      <div class="card-footer"><span class="card-points">${c.pts} pts</span><div class="card-diff">${dots}</div></div>
      <div class="card-solves">${c.solves} solves</div>
    </div>`;
  }).join('');
}

function filterCards(cat, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderChallenges(cat);
}

// MODAL
function openModal(id) {
  const c = challenges.find(x => x.id === id);
  currentChallenge = c;
  document.getElementById('m-cat').textContent = catLabels[c.cat];
  document.getElementById('m-cat').style.color = catColors[c.cat];
  document.getElementById('m-title').textContent = c.title;
  document.getElementById('m-pts').textContent = `${c.pts} points · ${c.solves} solves`;
  document.getElementById('m-desc').textContent = c.desc;
  document.getElementById('hint-text').textContent = c.hint;
  document.getElementById('hint-box').classList.remove('open');
  document.getElementById('hint-toggle-btn').textContent = '💡 Show Hint';
  document.getElementById('flag-input').value = '';
  const msg = document.getElementById('flag-msg');
  msg.className = 'flag-msg'; msg.textContent = '';
  document.getElementById('modal').classList.add('open');
}
function closeModal() { document.getElementById('modal').classList.remove('open'); currentChallenge = null; }
function closeModalOnBg(e) { if (e.target.id === 'modal') closeModal(); }
function toggleHint() {
  const box = document.getElementById('hint-box');
  const btn = document.getElementById('hint-toggle-btn');
  box.classList.toggle('open');
  btn.textContent = box.classList.contains('open') ? '💡 Hide Hint' : '💡 Show Hint';
}
function submitFlag() {
  const input = document.getElementById('flag-input').value.trim();
  const msg = document.getElementById('flag-msg');
  if (!input) return;
  if (input === currentChallenge.flag) {
    if (currentChallenge.solved) {
      msg.textContent = 'Already solved — no duplicate points.';
      msg.className = 'flag-msg wrong';
      return;
    }
    msg.textContent = '✓ Correct! Flag captured. +' + currentChallenge.pts + ' points';
    msg.className = 'flag-msg correct';
    currentChallenge.solved = true;
    updateUserScore(currentChallenge.pts, currentChallenge.title);
    renderChallenges();
  } else {
    msg.textContent = '✗ Incorrect flag. Keep trying.';
    msg.className = 'flag-msg wrong';
  }
}

// TEAM
function renderTeam() {
  document.getElementById('team-grid').innerHTML = team.map(m => {
    const initials = m.name.split(' ').map(w => w[0]).join('').substring(0, 2);
    return `<div class="team-card"><div class="team-avatar" style="background:${m.color}22;color:${m.color}">${initials}</div><div class="team-name">${m.name}</div><div class="team-role">${m.role}</div></div>`;
  }).join('');
}

// NAV
function goTo(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-links li a').forEach(a => a.classList.remove('active'));
  document.getElementById('page-' + page).classList.add('active');
  document.getElementById('nav-' + page).classList.add('active');
  window.scrollTo(0, 0);
}

// TOAST
let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 3500);
}
</script>
</body>
</html>

