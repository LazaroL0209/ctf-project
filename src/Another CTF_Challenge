<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shadow Key | CTF Challenge</title>
  <style>
    :root {
      --bg: #0b1020;
      --bg-soft: #121933;
      --panel: rgba(16, 24, 52, 0.82);
      --panel-2: rgba(11, 17, 38, 0.9);
      --line: rgba(120, 141, 201, 0.25);
      --text: #eef2ff;
      --muted: #a8b1d1;
      --accent: #6ee7ff;
      --accent-2: #8b5cf6;
      --success: #34d399;
      --danger: #fb7185;
      --warning: #fbbf24;
      --shadow: 0 24px 80px rgba(0, 0, 0, 0.35);
      --radius: 24px;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(139, 92, 246, 0.16), transparent 28%),
        radial-gradient(circle at top right, rgba(110, 231, 255, 0.14), transparent 22%),
        linear-gradient(180deg, #08101f 0%, #0a1020 45%, #0e1327 100%);
      min-height: 100vh;
    }

    .grid {
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 28px 28px;
      mask-image: linear-gradient(to bottom, rgba(0,0,0,0.45), rgba(0,0,0,0.9));
      pointer-events: none;
    }

    .wrap {
      width: min(1180px, calc(100% - 32px));
      margin: 0 auto;
      padding: 28px 0 48px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 24px;
      padding: 16px 18px;
      border: 1px solid var(--line);
      background: rgba(10, 15, 31, 0.65);
      backdrop-filter: blur(14px);
      border-radius: 18px;
      box-shadow: var(--shadow);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .brand-mark {
      width: 40px;
      height: 40px;
      display: grid;
      place-items: center;
      border-radius: 14px;
      color: #08101f;
      background: linear-gradient(135deg, var(--accent), #c4b5fd);
      box-shadow: 0 8px 30px rgba(110, 231, 255, 0.22);
      font-size: 18px;
    }

    .top-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border: 1px solid var(--line);
      border-radius: 999px;
      color: var(--muted);
      background: rgba(255,255,255,0.03);
      font-size: 0.95rem;
    }

    .hero {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 24px;
      margin-bottom: 24px;
    }

    .card {
      border: 1px solid var(--line);
      background: linear-gradient(180deg, var(--panel), var(--panel-2));
      backdrop-filter: blur(18px);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .hero-main {
      padding: 34px;
      position: relative;
      overflow: hidden;
    }

    .hero-main::after {
      content: "";
      position: absolute;
      right: -80px;
      top: -80px;
      width: 240px;
      height: 240px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(110, 231, 255, 0.16), transparent 65%);
      pointer-events: none;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--accent);
      border: 1px solid rgba(110, 231, 255, 0.22);
      background: rgba(110, 231, 255, 0.06);
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 0.88rem;
      margin-bottom: 18px;
    }

    h1 {
      margin: 0 0 12px;
      font-size: clamp(2rem, 4vw, 4rem);
      line-height: 0.98;
      letter-spacing: -0.04em;
    }

    .sub {
      margin: 0;
      color: var(--muted);
      font-size: 1.08rem;
      line-height: 1.7;
      max-width: 60ch;
    }

    .hero-stats {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
      padding: 22px;
    }

    .stat-box {
      padding: 18px;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: rgba(255,255,255,0.03);
    }

    .label {
      color: var(--muted);
      font-size: 0.86rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .value {
      font-size: 1.55rem;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .content {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 24px;
    }

    .section {
      padding: 28px;
    }

    .section h2 {
      margin: 0 0 10px;
      font-size: 1.35rem;
      letter-spacing: -0.03em;
    }

    .section p {
      margin: 0;
      color: var(--muted);
      line-height: 1.75;
    }

    .terminal {
      margin-top: 18px;
      border: 1px solid var(--line);
      border-radius: 20px;
      overflow: hidden;
      background: rgba(4, 8, 19, 0.9);
    }

    .terminal-head {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 16px;
      background: rgba(255,255,255,0.04);
      border-bottom: 1px solid var(--line);
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.45);
    }

    .terminal-body {
      padding: 20px;
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
      color: #dce5ff;
      line-height: 1.8;
      font-size: 0.95rem;
    }

    .terminal-body .muted { color: #7e8bb3; }
    .terminal-body .accent { color: var(--accent); }
    .terminal-body .warn { color: var(--warning); }

    .note-grid {
      display: grid;
      gap: 14px;
      margin-top: 18px;
    }

    .note {
      padding: 16px 18px;
      border-radius: 18px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.03);
    }

    .challenge-form {
      display: grid;
      gap: 14px;
      margin-top: 20px;
    }

    label {
      font-weight: 600;
      color: #dce5ff;
    }

    input[type="text"] {
      width: 100%;
      border: 1px solid var(--line);
      background: rgba(6, 10, 22, 0.86);
      color: var(--text);
      border-radius: 16px;
      padding: 16px 18px;
      font-size: 1rem;
      outline: none;
      transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
    }

    input[type="text"]:focus {
      border-color: rgba(110, 231, 255, 0.62);
      box-shadow: 0 0 0 4px rgba(110, 231, 255, 0.12);
      transform: translateY(-1px);
    }

    .button-row {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    button {
      border: 0;
      cursor: pointer;
      border-radius: 16px;
      padding: 14px 18px;
      font-size: 0.98rem;
      font-weight: 700;
      transition: transform 0.18s ease, opacity 0.18s ease, box-shadow 0.18s ease;
    }

    button:hover { transform: translateY(-1px); }
    button:active { transform: translateY(0); }

    .primary {
      color: #08101f;
      background: linear-gradient(135deg, var(--accent), #c4b5fd);
      box-shadow: 0 12px 34px rgba(110, 231, 255, 0.18);
    }

    .secondary {
      color: var(--text);
      background: rgba(255,255,255,0.06);
      border: 1px solid var(--line);
    }

    .feedback {
      min-height: 28px;
      font-weight: 600;
      letter-spacing: 0.01em;
    }

    .feedback.success { color: var(--success); }
    .feedback.error { color: var(--danger); }
    .feedback.info { color: var(--accent); }

    .hint-stack {
      display: grid;
      gap: 12px;
      margin-top: 18px;
    }

    details {
      border: 1px solid var(--line);
      border-radius: 18px;
      background: rgba(255,255,255,0.03);
      overflow: hidden;
    }

    summary {
      list-style: none;
      cursor: pointer;
      padding: 16px 18px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    summary::-webkit-details-marker { display: none; }

    .details-body {
      padding: 0 18px 18px;
      color: var(--muted);
      line-height: 1.7;
    }

    .footer {
      margin-top: 24px;
      padding: 18px 22px;
      border-radius: 18px;
      border: 1px solid var(--line);
      color: var(--muted);
      background: rgba(255,255,255,0.03);
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 12px;
      font-size: 0.95rem;
    }

    .success-panel {
      display: none;
      margin-top: 16px;
      padding: 18px;
      border-radius: 20px;
      border: 1px solid rgba(52, 211, 153, 0.28);
      background: rgba(52, 211, 153, 0.08);
    }

    .success-panel.show { display: block; }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 12px;
      padding: 9px 12px;
      border-radius: 999px;
      background: rgba(52, 211, 153, 0.12);
      color: var(--success);
      border: 1px solid rgba(52, 211, 153, 0.24);
      font-weight: 700;
      font-size: 0.95rem;
    }

    @media (max-width: 940px) {
      .hero, .content {
        grid-template-columns: 1fr;
      }

      .hero-main, .section, .hero-stats {
        padding: 24px;
      }
    }

    @media (max-width: 620px) {
      .wrap { width: min(100% - 20px, 1180px); }
      .topbar { padding: 14px; }
      h1 { font-size: 2.2rem; }
      .hero-stats { grid-template-columns: 1fr 1fr; gap: 12px; }
      .value { font-size: 1.2rem; }
      .button-row { flex-direction: column; }
      button { width: 100%; }
    }
  </style>
</head>
<body>
  <div class="grid"></div>
  <div class="wrap">
    <div class="topbar">
      <div class="brand">
        <div class="brand-mark">⚡</div>
        <div>
          <div>CTF Project</div>
          <div style="color: var(--muted); font-weight: 500; font-size: 0.9rem;">Clean UI inspired by picoCTF simplicity and polished challenge styling</div>
        </div>
      </div>
      <div class="top-meta">
        <div class="pill">Web / Logic</div>
        <div class="pill">Medium</div>
        <div class="pill">Single-Page Challenge</div>
      </div>
    </div>

    <section class="hero">
      <div class="card hero-main">
        <div class="eyebrow">Final Project Output • Cybersecurity Challenge</div>
        <h1>Shadow Key</h1>
        <p class="sub">
          Your team intercepted a suspicious training portal. The login is gone, the dashboard is scrubbed, and only fragments remain.
          Use the clue trail, inspect carefully, and submit the correct flag to unlock the hidden key.
        </p>
      </div>
      <div class="card hero-stats">
        <div class="stat-box">
          <div class="label">Category</div>
          <div class="value">Web Exploitation</div>
        </div>
        <div class="stat-box">
          <div class="label">Difficulty</div>
          <div class="value">Medium</div>
        </div>
        <div class="stat-box">
          <div class="label">Starting Points</div>
          <div class="value" id="pointsDisplay">200</div>
        </div>
        <div class="stat-box">
          <div class="label">Attempts</div>
          <div class="value" id="attemptsDisplay">0</div>
        </div>
      </div>
    </section>

    <section class="content">
      <div class="card section">
        <h2>Mission Brief</h2>
        <p>
          A leaked note says the answer is not hidden in plain sight. The flag format follows the standard CTF pattern and is built from a phrase suggested by the corrupted system logs below. Read the fragments carefully, connect the pattern, and think like an analyst.
        </p>

        <div class="terminal">
          <div class="terminal-head">
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
            <span style="margin-left: 8px; color: var(--muted); font-size: 0.92rem;">shadowkey.log</span>
          </div>
          <div class="terminal-body">
            <div><span class="muted">[04:41:08]</span> session initialized...</div>
            <div><span class="muted">[04:41:11]</span> training instance: <span class="accent">practice-shadow</span></div>
            <div><span class="muted">[04:41:17]</span> reminder: <span class="warn">the answer is built from what matters most</span></div>
            <div><span class="muted">[04:41:19]</span> ui review: clean layouts reduce confusion</div>
            <div><span class="muted">[04:41:22]</span> note: clutter hides meaning, structure reveals it</div>
            <div><span class="muted">[04:41:28]</span> final marker: <span class="accent">clarity_over_clutter</span></div>
            <div><span class="muted">[04:41:31]</span> expected wrapper: flag{'{'}phrase{'}'}</div>
          </div>
        </div>

        <div class="note-grid">
          <div class="note"><strong>Objective:</strong> Find the correct flag by using the challenge clue and page content.</div>
          <div class="note"><strong>Tip:</strong> This page is intentionally simple and focused, based on your team findings that users solve challenges better when the interface is clean and not overloaded.</div>
        </div>
      </div>

      <div class="card section">
        <h2>Submit the Flag</h2>
        <p>Enter your answer in the format <strong>flag{'{'}your_answer_here{'}'}</strong>.</p>

        <form class="challenge-form" id="challengeForm">
          <div>
            <label for="flagInput">Flag</label>
            <input id="flagInput" type="text" autocomplete="off" placeholder="flag{...}" />
          </div>
          <div class="button-row">
            <button class="primary" type="submit">Check Flag</button>
            <button class="secondary" type="button" id="resetBtn">Reset</button>
          </div>
          <div class="feedback info" id="feedback">Use the clue trail and look for the final marker.</div>
        </form>

        <div class="success-panel" id="successPanel">
          <strong>Challenge solved.</strong>
          <div style="color: var(--muted); margin-top: 8px; line-height: 1.7;">
            Nice work. You found the hidden phrase and followed the proper flag structure.
          </div>
          <div class="badge">✔ Solved Badge Earned</div>
        </div>

        <div class="hint-stack">
          <details>
            <summary>Hint 1 <span style="color: var(--muted); font-weight: 500;">Small push</span></summary>
            <div class="details-body">The log tells you the exact phrase to focus on. Do not overthink the clue.</div>
          </details>
          <details>
            <summary>Hint 2 <span style="color: var(--muted); font-weight: 500;">Stronger direction</span></summary>
            <div class="details-body">Use the phrase that appears after <em>final marker</em> and place it inside the wrapper shown on the last line.</div>
          </details>
          <details>
            <summary>Hint 3 <span style="color: var(--muted); font-weight: 500;">Almost there</span></summary>
            <div class="details-body">The correct answer is based on the phrase <code>clarity_over_clutter</code>.</div>
          </details>
        </div>
      </div>
    </section>

    <div class="footer">
      <span>Built for a final CTF project presentation</span>
      <span>Design direction: clean, readable, uncluttered, challenge-first</span>
    </div>
  </div>

  <script>
    const form = document.getElementById('challengeForm');
    const flagInput = document.getElementById('flagInput');
    const feedback = document.getElementById('feedback');
    const attemptsDisplay = document.getElementById('attemptsDisplay');
    const pointsDisplay = document.getElementById('pointsDisplay');
    const successPanel = document.getElementById('successPanel');
    const resetBtn = document.getElementById('resetBtn');

    let attempts = 0;
    let points = 200;
    let solved = false;

    // Flag is lightly obfuscated instead of left as plain text.
    const encoded = 'ZmxhZ3tjbGFyaXR5X292ZXJfY2x1dHRlcn0=';
    const correctFlag = atob(encoded);

    function setFeedback(message, type) {
      feedback.textContent = message;
      feedback.className = `feedback ${type}`;
    }

    form.addEventListener('submit', function (event) {
      event.preventDefault();
      if (solved) {
        setFeedback('You already solved this challenge.', 'success');
        return;
      }

      const guess = flagInput.value.trim();
      attempts += 1;
      attemptsDisplay.textContent = attempts;

      if (guess === correctFlag) {
        solved = true;
        setFeedback('Correct flag submitted.', 'success');
        successPanel.classList.add('show');
        flagInput.disabled = true;
        pointsDisplay.textContent = points;
        return;
      }

      points = Math.max(80, points - 10);
      pointsDisplay.textContent = points;

      if (!guess.startsWith('flag{') || !guess.endsWith('}')) {
        setFeedback('Wrong format. Make sure your answer starts with flag{ and ends with }.', 'error');
      } else {
        setFeedback('Not quite. Re-read the final marker and the wrapper line in the log.', 'error');
      }
    });

    resetBtn.addEventListener('click', function () {
      attempts = 0;
      points = 200;
      solved = false;
      flagInput.disabled = false;
      flagInput.value = '';
      attemptsDisplay.textContent = attempts;
      pointsDisplay.textContent = points;
      successPanel.classList.remove('show');
      setFeedback('Challenge reset. Try again.', 'info');
    });
  </script>
</body>
</html>

